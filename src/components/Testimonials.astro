---
// Testimonials section — real client quotes, 4-card grid
import TiltCard from './TiltCard.astro';

const testimonials = [
  {
    quote: 'I am amazed by their work. I am a fitness content creator, and I was struggling for social media reach. They helped me get more reachability and visibility.',
    name: 'Rajat Sharma',
    initials: 'RS',
  },
  {
    quote: 'I required an urgent website for showcasing my work. Their website creation services are so good — my need was fulfilled in no time.',
    name: 'Satvik Maheshwari',
    initials: 'SM',
  },
  {
    quote: 'I needed search engine optimization for my personal blog website. I am really impressed with the work they did for me.',
    name: 'Prerna Kaushik',
    initials: 'PK',
  },
  {
    quote: 'I needed help with email marketing for my business. They provided me a great service — their team is very professional, and I am happy with their work.',
    name: 'Shashank Vashishtha',
    initials: 'SV',
  },
];
---
<section class="bg-background px-6 py-20 md:py-28">
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">

      <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Client Testimonials</h2>
    </div>

    <!-- 4-column equal-sized card grid -->
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {testimonials.map((t, i) => (
        <TiltCard revealDelay={i + 1}>
          <div class="glass-card flex h-full flex-col rounded-card border p-8 transition-[box-shadow] duration-300">
            <!-- Star rating -->
            <div class="flex gap-1 text-primary" role="img" aria-label="5 out of 5 stars">
              {[1, 2, 3, 4, 5].map((s) => (
                <svg class="h-5 w-5 transition-transform duration-300" style={`transition-delay: ${s * 50}ms;`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="mt-4 text-body leading-relaxed text-text-secondary">
              &ldquo;{t.quote}&rdquo;
            </blockquote>

            <!-- Author — pushed to bottom -->
            <div class="mt-auto pt-6">
              <div class="flex items-center gap-3">
                <!-- Avatar initials circle -->
                <div class="inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-primary text-body font-semibold text-white transition-transform duration-300 group-hover:scale-110">
                  {t.initials}
                </div>
                <div class="text-body font-semibold text-text-primary">{t.name}</div>
              </div>
            </div>
          </div>
        </TiltCard>
      ))}
    </div>
  </div>
</section>
