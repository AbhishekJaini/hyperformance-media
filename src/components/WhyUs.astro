---
// Why Us section — 3-card grid with hover lift, surface background
// Upgraded with background tech pattern and enhanced icon blocks
const cards = [
  {
    title: 'SEO & Search Optimization',
    body: 'We climb the rankings so your brand gets found first. Technical SEO, content strategy, and keyword targeting that drives organic traffic.',
    icon: 'M21 21l-4.35-4.35M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16z',
    link: '/services',
  },
  {
    title: 'Lead Generation',
    body: 'Turn visitors into qualified leads with data-driven funnels, landing pages, and conversion optimization built to scale your pipeline.',
    icon: 'M3 3v18h18M7 14l4-4 3 3 5-6',
    link: '/services',
  },
  {
    title: 'Website Creation',
    body: 'Fast, beautiful, conversion-ready websites. From design to deployment, we build sites that look great and perform even better.',
    icon: 'M3 5h18v14H3zM3 9h18M9 9v10',
    link: '/services',
  },
];
---
<section id="why-us" class="scroll-mt-24 relative overflow-hidden bg-surface px-6 py-20 md:py-28">
  <!-- Decorative background pattern (tech grid) -->
  <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center opacity-[0.03]">
    <svg width="100%" height="100%" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="techGrid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M40 0L0 40M0 0l40 40" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.5" />
          <circle cx="20" cy="20" r="2" fill="currentColor" />
          <path d="M20 0v40M0 20h40" stroke="currentColor" stroke-width="0.5" fill="none" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#techGrid)" class="text-primary" />
    </svg>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-background px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary shadow-sm" data-reveal="fade">
        <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
        Why Hyperformance Media
      </span>
      <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Why Choose Us</h2>
      <p class="mx-auto mt-4 max-w-xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        We combine AI-powered tooling with marketing fundamentals to deliver growth that is measurable, sustainable, and scalable.
      </p>
    </div>

    <!-- 3-column card grid with hover lift -->
    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {cards.map((card, i) => (
        <div
          class="group relative overflow-hidden rounded-card border border-border bg-background p-8 shadow-card transition-all duration-300 hover:shadow-card-hover hover:-translate-y-2 hover:border-primary/40"
          data-reveal="scale"
          data-reveal-delay={i + 1}
        >
          <!-- Accent top border that appears on hover -->
          <div class="absolute inset-x-0 top-0 h-1 bg-primary opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          
          <!-- Enhanced Icon Block -->
          <div class="relative mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/5 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:scale-110 group-hover:shadow-lg">
            <div class="absolute inset-0 rounded-2xl border border-primary/20 scale-110 opacity-0 transition-all duration-500 group-hover:scale-125 group-hover:opacity-100 group-hover:border-primary/30"></div>
            <svg class="relative z-10 h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
            </svg>
          </div>
          
          <h3 class="mt-2 text-h4 text-text-primary group-hover:text-primary transition-colors duration-300">{card.title}</h3>
          <p class="mt-4 text-body leading-relaxed text-text-secondary">{card.body}</p>

          <!-- Learn more link — appears with arrow on hover -->
          <a
            href={card.link}
            class="mt-8 inline-flex items-center gap-2 text-body font-medium text-primary transition-colors hover:text-primary-dark"
          >
            Learn more about {card.title}
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
