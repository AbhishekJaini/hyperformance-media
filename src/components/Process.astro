---
// Process section — 4-step card-based layout with icons and connecting flow
// Inspired by Gamma / HoneyBook process patterns: numbered cards with visual weight
const steps = [
  {
    num: '01',
    title: 'Strategy',
    body: 'We audit your brand, market, and goals to build a data-backed growth roadmap.',
    icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9l2 2 4-4',
  },
  {
    num: '02',
    title: 'Design',
    body: 'We craft the visual and content experience — sites, pages, and assets that convert.',
    icon: 'M7 8l-4 4 4 4m10-8l4 4-4 4m-4-12l-2 16',
  },
  {
    num: '03',
    title: 'Develop',
    body: 'We build, integrate, and optimize everything for speed, SEO, and scale.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    num: '04',
    title: 'Support',
    body: 'We monitor, report, and refine continuously so results compound over time.',
    icon: 'M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z',
  },
];
---
<section class="bg-background px-6 py-20 md:py-28">
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary" data-reveal="fade">
        <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
        Our Process
      </span>
      <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">How We Work</h2>
      <p class="mx-auto mt-4 max-w-xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        A proven 4-step framework that turns your marketing goals into measurable growth.
      </p>
    </div>

    <!-- 4-step card grid with connecting flow -->
    <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <div
          class="group relative rounded-card border border-border bg-background p-8 shadow-card transition-all duration-300 hover:shadow-card-hover hover:-translate-y-2 hover:border-primary/30"
          data-reveal="scale"
          data-reveal-delay={i + 1}
        >
          <!-- Step number badge -->
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-button bg-primary/10 text-body font-bold text-primary-dark transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-110">
            {step.num}
          </div>

          <h3 class="mt-5 text-h4 text-text-primary">{step.title}</h3>
          <p class="mt-3 text-body text-text-secondary">{step.body}</p>

          <!-- Arrow connector (desktop only, not on last card) -->
          {i < steps.length - 1 && (
            <div class="absolute -right-3 top-1/2 z-10 hidden h-6 w-6 -translate-y-1/2 items-center justify-center lg:flex">
              <svg class="h-5 w-5 text-border transition-all duration-300 group-hover:text-primary group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
