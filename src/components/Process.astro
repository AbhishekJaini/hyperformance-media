---
// Process section — 4-step card-based layout with icons and connecting flow
// Upgraded with animated connection line and enhanced step cards
const steps = [
  {
    num: '01',
    title: 'Strategy',
    body: 'We audit your brand, market, and goals to build a data-backed growth roadmap.',
    icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9l2 2 4-4',
  },
  {
    num: '02',
    title: 'Design',
    body: 'We craft the visual and content experience — sites, pages, and assets that convert.',
    icon: 'M7 8l-4 4 4 4m10-8l4 4-4 4m-4-12l-2 16',
  },
  {
    num: '03',
    title: 'Develop',
    body: 'We build, integrate, and optimize everything for speed, SEO, and scale.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    num: '04',
    title: 'Support',
    body: 'We monitor, report, and refine continuously so results compound over time.',
    icon: 'M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z',
  },
];
---
<section class="process-section relative bg-background px-6 py-20 md:py-28 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="pointer-events-none absolute left-0 top-0 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/5 blur-[120px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-0 bottom-0 h-[600px] w-[600px] translate-x-1/2 translate-y-1/2 rounded-full bg-primary/5 blur-[120px]" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">How We Work</h2>
      <p class="mx-auto mt-4 max-w-xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        An engineered 4-step framework that turns raw traffic into measurable revenue.
      </p>
    </div>

    <!-- 4-step container with connecting line -->
    <div class="relative mt-20">
      
      <!-- Desktop continuous connecting line -->
      <div class="absolute left-[50px] right-[50px] top-10 hidden h-0.5 lg:block border-t-2 border-dashed border-border" aria-hidden="true">
        <!-- Animated overlay line that draws across -->
        <div class="h-full bg-primary" style="width: 100%; animation: drawLine 3s ease-out forwards; animation-timeline: view(); animation-range: entry 25% cover 50%;"></div>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
        {steps.map((step, i) => (
          <div class="process-step-gsap group relative text-center lg:text-left opacity-0 translate-y-8">
            <!-- Giant Step Number -->
            <div class="relative z-10 mb-4 inline-flex items-center justify-center lg:mx-0">
              <span class="text-7xl font-black text-border transition-colors duration-500 group-hover:text-primary/30 lg:text-8xl">{step.num}</span>
            </div>

            <!-- Card Content -->
            <div class="relative z-20 -mt-8 pt-4 lg:-mt-10 lg:pt-6">
              <h3 class="text-h4 text-text-primary">{step.title}</h3>
              <p class="mt-3 text-body text-text-secondary">{step.body}</p>
            </div>
            
            <!-- Mobile connector (optional, kept simple) -->
            {i < steps.length - 1 && (
              <div class="absolute -bottom-8 left-1/2 flex h-8 w-0.5 -translate-x-1/2 items-center justify-center lg:hidden">
                <div class="h-full w-full border-l-2 border-dashed border-border"></div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes drawLine {
    from { width: 0%; }
    to { width: 100%; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  gsap.registerPlugin(ScrollTrigger);
  
  // We only run this on the client side
  if (typeof window !== 'undefined') {
    gsap.to(".process-step-gsap", { 
      opacity: 1, 
      y: 0, 
      duration: 0.8, 
      stagger: 0.15, 
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".process-section",
        start: "top 75%",
      }
    });
  }
</script>
