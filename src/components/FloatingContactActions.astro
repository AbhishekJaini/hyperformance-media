      <path d="M12.04 2a9.8 9.8 0 0 0-8.35 14.94L2.5 21.3l4.53-1.15A9.8 9.8 0 1 0 12.04 2Zm0 17.84a8.03 8.03 0 0 1-4.1-1.12l-.29-.17-2.69.68.72-2.62-.19-.3a8.03 8.03 0 1 1 6.56 3.53Zm4.4-6.02c-.24-.12-1.43-.7-1.65-.78-.22-.08-.38-.12-.54.12-.16.24-.62.78-.76.94-.14.16-.28.18-.52.06a6.4 6.4 0 0 1-1.89-1.16 7.1 7.1 0 0 1-1.31-1.63c-.14-.24-.02-.37.1-.49.1-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.4h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.65.58.25 1.03.4 1.38.51.58.18 1.1.15 1.51.09.46-.07 1.43-.58 1.63-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z" />
    </svg>
    <span class="pointer-events-none absolute right-[calc(100%+0.75rem)] whitespace-nowrap rounded-md bg-text-primary px-3 py-1.5 text-xs font-semibold text-background opacity-0 shadow-sm transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100">WhatsApp us</span>
