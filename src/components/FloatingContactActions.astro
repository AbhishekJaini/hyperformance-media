---
const PHONE_HREF = 'tel:+919643534849';
const WHATSAPP_HREF = 'https://web.whatsapp.com/send?phone=+919643534849';
---

<aside class="fixed bottom-[max(1rem,env(safe-area-inset-bottom))] right-[max(1rem,env(safe-area-inset-right))] z-40 flex flex-col gap-3" aria-label="Contact options">
  <a href={PHONE_HREF} class="group relative flex h-12 w-12 items-center justify-center rounded-full bg-primary text-black shadow-lg shadow-black/20 ring-1 ring-white/20" aria-label="Call us">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 4.5A2.25 2.25 0 0 1 4.5 2.25h2.386c.51 0 .956.343 1.087.835l1.1 4.122a1.125 1.125 0 0 1-.417 1.159l-1.293.97a11.25 11.25 0 0 0 5.303 5.303l.97-1.293a1.125 1.125 0 0 1 1.159-.417l4.122 1.1c.492.131.835.577.835 1.087V19.5a2.25 2.25 0 0 1-2.25 2.25H18C9.302 21.75 2.25 14.698 2.25 6V4.5Z" />
    </svg>
    <span class="pointer-events-none absolute right-[calc(100%+0.75rem)] whitespace-nowrap rounded-md bg-text-primary px-3 py-1.5 text-xs font-semibold text-background opacity-0 shadow-sm transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100">Call us</span>
  </a>

  <a href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer" class="group relative flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg shadow-black/20 ring-1 ring-white/20" aria-label="Message us on WhatsApp">
