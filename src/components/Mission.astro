---
import { Image } from 'astro:assets';
import missionGraphic from '../assets/mission-graphic.jpg';
import missionGraphicDark from '../assets/mission-graphic-dark.png';
---

<section class="relative overflow-hidden bg-background px-6 py-20 md:py-28">
  <!-- Subtle background glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/5 blur-[100px]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      
      <!-- Graphic Side -->
      <div class="order-2 lg:order-1 relative" data-reveal="scale">
        <div class="relative aspect-square w-full max-w-md mx-auto lg:max-w-none">
          <!-- Decorative ring behind image -->
          <div class="absolute inset-0 rounded-full border border-primary/20 scale-105" style="animation: spin 30s linear infinite;"></div>
          <div class="absolute inset-0 rounded-full border border-primary/10 scale-110" style="animation: spin 40s linear infinite reverse;"></div>
          
          <Image 
            src={missionGraphic} 
            alt="Hyperformance Media Mission and Energy" 
            class="h-full w-full rounded-full object-cover shadow-2xl ring-1 ring-border/50 mix-blend-multiply dark:hidden"
            width={600}
            height={600}
          />
          <Image
            src={missionGraphicDark}
            alt="Hyperformance Media Mission and Energy"
            class="hidden h-full w-full rounded-full object-cover shadow-[0_24px_64px_rgb(0_229_255_/_0.12)] ring-1 ring-primary/30 dark:block"
            width={600}
            height={600}
          />
        </div>
      </div>

      <!-- Text Side -->
      <div class="order-1 lg:order-2 text-center lg:text-left">

        <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">
          Translating traffic into tangible revenue.
        </h2>
        
        <p class="mt-6 text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
          Most agencies optimize for clicks. We engineer for revenue. By fusing technical SEO, high-performance website architecture, and precision media buying, we build sustainable acquisition engines that compound over time.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start" data-reveal data-reveal-delay="3">
           <div class="flex items-center gap-2 text-body font-medium text-text-primary">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              Data-Driven
           </div>
           <div class="hidden sm:block h-1 w-1 rounded-full bg-border"></div>
           <div class="flex items-center gap-2 text-body font-medium text-text-primary">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              AI-Powered
           </div>
           <div class="hidden sm:block h-1 w-1 rounded-full bg-border"></div>
           <div class="flex items-center gap-2 text-body font-medium text-text-primary">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              Client-Focused
           </div>
        </div>
      </div>

    </div>
  </div>
</section>
