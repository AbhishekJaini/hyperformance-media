---
// Mission section — centered single block, white background
---
<section class="bg-background px-6 py-20 md:py-28">
  <div class="mx-auto max-w-3xl text-center">
    <span class="inline-flex items-center rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary" data-reveal="fade">
      <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
      Our Mission
    </span>
    <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">
      Empowering Brands Through Digital Marketing.
    </h2>
    <p class="mx-auto mt-6 max-w-3xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
      We bridge the gap between traditional marketing and modern digital strategy —
      combining SEO, website building, performance marketing, and social media
      optimization to help businesses grow online with measurable, lasting results.
    </p>
  </div>
</section>
