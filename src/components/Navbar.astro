---
import { Image } from 'astro:assets';
import logo from '../assets/logo-official.png';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Why Us', href: '/#why-us' },
  { label: 'Contact', href: '/contact' },
];
---
<header id="site-header" class="sticky top-0 z-50 bg-background border-b border-border transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300" aria-label="Main navigation">
    <!-- Logo - horizontal lockup from brand assets -->
    <a href="/" class="flex-shrink-0">
      <Image src={logo} alt="Hyperformance Media logo" height={40} width={121} class="h-10 w-auto transition-all duration-300" id="nav-logo" />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="relative text-body text-text-secondary transition-colors duration-200 hover:text-text-primary after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="/contact"
      class="hidden md:inline-flex items-center rounded-button bg-primary px-5 py-2.5 text-body font-medium text-white shadow-card transition-all duration-300 hover:bg-primary-dark hover:shadow-lg hover:-translate-y-0.5"
    >
      Contact Us
    </a>

    <!-- Mobile hamburger button -->
    <button
      id="nav-toggle"
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-button p-2 text-text-primary hover:bg-surface"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile slide-down menu -->
  <div id="nav-mobile" class="hidden md:hidden border-t border-border bg-background">
    <ul class="mx-auto max-w-7xl flex flex-col px-6 py-4 gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block rounded-button px-3 py-2.5 text-body text-text-secondary transition-colors hover:bg-surface hover:text-text-primary"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          class="block rounded-button bg-primary px-3 py-2.5 text-center text-body font-medium text-white shadow-card transition-colors hover:bg-primary-dark"
        >
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }

  // Navbar scroll shrink — reduces padding + adds stronger shadow when scrolled
  const header = document.getElementById('site-header');
  const logo = document.getElementById('nav-logo');
  if (header) {
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 20;
        if (scrolled) {
          header.style.boxShadow = '0 4px 20px rgba(15, 23, 42, 0.06)';
          header.style.borderColor = '#e2e8f0';
          if (logo) logo.style.transform = 'scale(0.9)';
        } else {
          header.style.boxShadow = '';
          if (logo) logo.style.transform = 'scale(1)';
        }
        ticking = false;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
