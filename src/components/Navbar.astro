---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
];
---
<header id="site-header" class="sticky top-0 z-50 bg-background border-b border-border transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex flex-shrink-0 items-center" id="nav-logo">
      <img src="/logo-header.png" alt="Hyperformance Media logo" width="205" height="68" class="block h-12 w-[145px] object-contain [image-rendering:-webkit-optimize-contrast] sm:h-14 sm:w-[175px] md:h-16 md:w-[205px] dark:hidden" />
      <img src="/logo-header-dark.png" alt="Hyperformance Media logo" width="205" height="68" class="hidden h-12 w-[145px] object-contain [image-rendering:-webkit-optimize-contrast] sm:h-14 sm:w-[175px] md:h-16 md:w-[205px] dark:block" />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium tracking-wide">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="relative uppercase text-text-secondary transition-colors duration-200 hover:text-text-primary after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA & Theme Toggle -->
    <div class="hidden md:flex items-center gap-4">
      <button
        id="theme-toggle"
        data-theme-toggle
        class="flex h-10 w-10 items-center justify-center rounded-full border border-border text-text-secondary transition-colors hover:border-primary hover:text-primary"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shows in dark mode) -->
        <svg id="theme-toggle-light-icon" data-theme-light-icon class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shows in light mode) -->
        <svg id="theme-toggle-dark-icon" data-theme-dark-icon class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-button bg-primary px-6 py-2.5 text-body font-semibold text-[#000000] shadow-card transition-all duration-300 hover:bg-primary-light hover:shadow-lg hover:-translate-y-0.5"
      >
        Book a Call
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M12 4l8 8-8 8" />
        </svg>
      </a>
    </div>

    <!-- Mobile controls retain access to both navigation and colour preference. -->
    <div class="flex items-center gap-2 md:hidden">
      <button
        type="button"
        data-theme-toggle
        class="flex h-11 w-11 items-center justify-center rounded-full border border-border text-text-secondary transition-colors hover:border-primary hover:text-primary"
        aria-label="Toggle dark mode"
      >
        <svg data-theme-light-icon class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l.707.707M17.657 17.657l.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg data-theme-dark-icon class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <button
        id="nav-toggle"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-border text-text-primary transition-colors hover:border-primary hover:bg-surface"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile slide-down menu -->
  <div id="nav-mobile" class="hidden md:hidden border-t border-border bg-background">
    <ul class="mx-auto max-w-7xl flex flex-col px-6 py-4 gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block rounded-button px-3 py-2.5 text-body text-text-secondary transition-colors hover:bg-surface hover:text-text-primary"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          class="block rounded-button bg-primary px-3 py-2.5 text-center text-body font-medium text-white shadow-card transition-colors hover:bg-primary-dark"
        >
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }

  // Navbar scroll shrink — reduces padding + adds stronger shadow when scrolled
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 20;
        if (scrolled) {
          header.style.boxShadow = document.documentElement.classList.contains('dark') ? '0 4px 20px rgba(0, 0, 0, 0.5)' : '0 4px 20px rgba(15, 23, 42, 0.06)';
          header.style.borderColor = 'transparent'; // Let the shadow do the work, or use a specific dark mode border
        } else {
          header.style.boxShadow = '';
          header.style.borderColor = '';
        }
        ticking = false;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Theme toggle logic
  const themeToggleBtns = document.querySelectorAll<HTMLElement>('[data-theme-toggle]');

  function syncThemeToggles() {
    const isDark = document.documentElement.classList.contains('dark');
    themeToggleBtns.forEach((button) => {
      button.querySelector('[data-theme-dark-icon]')?.classList.toggle('hidden', isDark);
      button.querySelector('[data-theme-light-icon]')?.classList.toggle('hidden', !isDark);
    });
  }

  syncThemeToggles();
  themeToggleBtns.forEach((button) => {
    button.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      syncThemeToggles();
    });
  });
</script>
