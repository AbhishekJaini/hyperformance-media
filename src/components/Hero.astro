---
import { Image } from 'astro:assets';
import logoVerticalTransparent from '../assets/logo-vertical-transparent.png';
import lightHeroLogo from '../assets/logo-hero-light-transparent.png';

// Marquee items
const marqueeItems = [
  "AI PORTALS", "•", "PERFORMANCE", "•", "WEBSITES", "•", "GROWTH", "•", "APPS", "•", "E-COMMERCE", "•",
  "AI PORTALS", "•", "PERFORMANCE", "•", "WEBSITES", "•", "GROWTH", "•", "APPS", "•", "E-COMMERCE", "•",
];
---

<section class="relative overflow-hidden bg-background pt-20 pb-36 md:pt-28 md:pb-44">
  <!-- Grid background (from screenshot) -->
  <div class="pointer-events-none absolute inset-0 opacity-10">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="heroGrid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M60 0L0 0M0 0l0 60" stroke="currentColor" stroke-width="1" fill="none" class="text-text-primary" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#heroGrid)" />
    </svg>
  </div>

  <!-- Decorative ambient glows -->
  <div
    class="pointer-events-none absolute left-0 top-0 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute right-0 top-1/4 h-[800px] w-[800px] translate-x-1/3 rounded-full bg-primary/5 blur-[120px]"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-8">
      
      <!-- Left side: Text content -->
      <div class="max-w-2xl text-left">
        <!-- Eyebrow / label -->
        <span class="hero-item-gsap inline-flex items-center gap-2.5 rounded-full border border-border bg-surface/50 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-text-secondary backdrop-blur-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true"></span>
          Data-Driven SEO & Growth Agency
        </span>

        <!-- Headline -->
        <h1 class="hero-item-gsap mt-5 text-[clamp(2.2rem,9vw,4.5rem)] font-extrabold leading-[1.04] tracking-tight text-text-primary">
          We build websites<br />
          <span class="text-primary">that drive growth</span><br />
          predictably.
        </h1>

        <!-- Subtext -->
        <p class="hero-item-gsap mt-6 max-w-xl text-lg leading-relaxed text-text-secondary">
          We don't just run campaigns. We build robust digital infrastructure—high-converting websites, SEO-driven traffic engines, and precise media buying—that turns traffic into measurable revenue and sustainable growth.
        </p>

        <!-- CTAs -->
        <div class="hero-item-gsap mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="/contact"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-8 py-3.5 text-body font-bold text-black shadow-card transition-all duration-300 hover:bg-primary-light hover:shadow-lg sm:w-auto"
          >
            Scale your revenue
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 19L20 5M20 5v10M20 5H10" />
            </svg>
          </a>
          <a
            href="/services"
            class="inline-flex w-full items-center justify-center rounded-full border border-border bg-surface dark:bg-transparent px-8 py-3.5 text-body font-medium text-text-primary transition-all duration-300 hover:border-primary hover:text-primary sm:w-auto"
          >
            See our process
          </a>
        </div>
      </div>

      <!-- Right side: Concentric Circles & Floating Logo -->
      <div class="hero-graphic-gsap relative mx-auto flex h-[min(82vw,500px)] w-full max-w-lg items-center justify-center lg:mx-0 lg:max-w-none">
        
        <!-- Concentric rings (Centered explicitly) -->
        <div class="absolute left-1/2 top-1/2 h-[min(64vw,400px)] w-[min(64vw,400px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-primary/20 bg-transparent shadow-[inset_0_0_80px_theme(colors.primary/5%)]"></div>
        <div class="absolute left-1/2 top-1/2 h-[min(88vw,550px)] w-[min(88vw,550px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-primary/10 bg-transparent"></div>
        
        <!-- Theme-specific assets retain contrast and clean edges on both surfaces. -->
        <div class="relative z-10 flex items-center justify-center" style="animation: float-random 10s ease-in-out infinite;">
          <Image 
            src={lightHeroLogo}
            alt="Hyperformance Media"
            class="h-auto w-48 object-contain drop-shadow-[0_0_36px_theme(colors.primary/20%)] dark:hidden sm:w-56 md:w-80"
          />
          <Image
            src={logoVerticalTransparent} 
            alt="Hyperformance Media" 
            class="hidden h-auto w-48 object-contain drop-shadow-[0_0_60px_theme(colors.primary/30%)] dark:block sm:w-56 md:w-80"
          />
        </div>
      </div>
      
    </div>
  </div>

  <!-- Marquee Banner (Absolute Bottom) -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden bg-primary py-5">
    <div class="flex whitespace-nowrap" style="animation: marquee 20s linear infinite;">
      {marqueeItems.map((item) => (
        <span class="mx-4 text-2xl font-black uppercase tracking-widest text-black">
          {item}
        </span>
      ))}
      {/* Duplicate for seamless looping */}
      {marqueeItems.map((item) => (
        <span class="mx-4 text-2xl font-black uppercase tracking-widest text-[#000000]" aria-hidden="true">
          {item}
        </span>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  
  if (typeof window !== 'undefined') {
    // Staggered entrance for the left content — animate FROM hidden state
    // Content is visible by default for LCP; GSAP enhances with animation
    gsap.from(".hero-item-gsap", {
      opacity: 0,
      y: 30,
      duration: 1,
      stagger: 0.15,
      ease: "power4.out",
      delay: 0.2
    });
    
    // Scale and fade in the graphic side
    gsap.from(".hero-graphic-gsap", {
      opacity: 0,
      scale: 0.95,
      duration: 1.5,
      ease: "power3.out",
      delay: 0.6
    });
  }
</script>
