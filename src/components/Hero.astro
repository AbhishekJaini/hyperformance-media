---
import { Image } from 'astro:assets';
import heroGraphic from '../assets/hero-graphic.jpg';
---

<section class="relative overflow-hidden bg-background px-6 pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Video background with blue overlay -->
  <div class="absolute inset-0 z-0">
    <video class="h-full w-full object-cover opacity-[0.15]" autoplay loop muted playsinline>
      <source src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260503_104800_bc43ae09-f494-43e3-97d7-2f8c1692cfd7.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-primary mix-blend-multiply opacity-[0.05]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-background/80 via-background/40 to-background"></div>
  </div>

  <!-- Decorative floating orbs -->
  <div
    class="pointer-events-none absolute -left-32 top-32 h-64 w-64 rounded-full bg-primary/20 blur-3xl"
    style="animation: float 8s ease-in-out infinite;"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-primary/10 blur-3xl"
    style="animation: float 12s ease-in-out infinite reverse;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-8">
      
      <!-- Left side: Text content -->
      <div class="max-w-2xl text-left">
        <!-- Eyebrow / label -->
        <span class="inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary shadow-sm ring-1 ring-border" data-reveal="fade">
          <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
          AI-Powered Digital Marketing Agency
        </span>

        <!-- Headline -->
        <h1 class="mt-6 text-4xl font-bold leading-tight text-text-primary sm:text-5xl md:text-h1" data-reveal data-reveal-delay="1">
          Next-Gen Marketing,<br class="hidden sm:block" />
          <span class="text-primary">Powered by AI.</span>
        </h1>

        <!-- Subtext -->
        <p class="mt-6 text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
          We're a results-driven digital marketing agency helping brands grow online
          through SEO, web design, social media, and content that converts.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row" data-reveal data-reveal-delay="3">
          <a
            href="/contact"
            class="inline-flex w-full items-center justify-center rounded-button bg-primary px-7 py-3.5 text-body font-medium text-white shadow-card transition-all hover:bg-primary-dark hover:-translate-y-0.5 hover:shadow-card-hover sm:w-auto"
          >
            Book Your Free Strategy Call
          </a>
          <a
            href="/services"
            class="inline-flex w-full items-center justify-center rounded-button border border-border bg-background px-7 py-3.5 text-body font-medium text-text-primary transition-all hover:border-primary hover:text-primary hover:-translate-y-0.5 shadow-sm sm:w-auto"
          >
            Our Services
          </a>
        </div>
      </div>

      <!-- Right side: Hero Graphic -->
      <div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none" data-reveal="right" data-reveal-delay="2">
        <div class="relative rounded-2xl bg-surface/50 p-2 shadow-2xl ring-1 ring-border/50 backdrop-blur-sm">
          <Image 
            src={heroGraphic} 
            alt="AI Powered Marketing Growth Visualization" 
            class="w-full rounded-xl object-cover shadow-inner"
            width={800}
            height={800}
          />
          
          <!-- Floating UI elements overlay -->
          <div class="absolute -left-6 bottom-12 rounded-xl bg-white p-4 shadow-xl ring-1 ring-border/50" style="animation: float 6s ease-in-out infinite 1s;">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <div>
                <p class="text-body-sm font-bold text-text-primary">3.2x Growth</p>
                <p class="text-xs text-text-secondary">Average in 6 months</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
