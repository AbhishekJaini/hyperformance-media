---
import { Image } from 'astro:assets';
import logoForHeroLight from '../assets/logo-official.png';
import logoForHeroDark from '../assets/logo-icon.jpeg';

// Marquee items
const marqueeItems = [
  "AI PORTALS", "✦", "PERFORMANCE", "✦", "WEBSITES", "✦", "GROWTH", "✦", "APPS", "✦", "E-COMMERCE", "✦",
  "AI PORTALS", "✦", "PERFORMANCE", "✦", "WEBSITES", "✦", "GROWTH", "✦", "APPS", "✦", "E-COMMERCE", "✦",
];
---

<section class="relative overflow-hidden bg-background pt-32 pb-48 md:pt-40 md:pb-56">
  <!-- Grid background (from screenshot) -->
  <div class="pointer-events-none absolute inset-0 opacity-10">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="heroGrid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M60 0L0 0M0 0l0 60" stroke="currentColor" stroke-width="1" fill="none" class="text-text-primary" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#heroGrid)" />
    </svg>
  </div>

  <!-- Decorative ambient glows -->
  <div
    class="pointer-events-none absolute left-0 top-0 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute right-0 top-1/4 h-[800px] w-[800px] translate-x-1/3 rounded-full bg-primary/5 blur-[120px]"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-8">
      
      <!-- Left side: Text content -->
      <div class="max-w-2xl text-left">
        <!-- Eyebrow / label -->
        <span class="inline-flex items-center gap-2 rounded-full border border-border bg-transparent px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-text-secondary" data-reveal="fade">
          <svg class="h-3.5 w-3.5 text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6L12 2Z" />
          </svg>
          AI-Powered Digital Marketing
        </span>

        <!-- Headline -->
        <h1 class="mt-8 text-5xl font-extrabold leading-[1.1] tracking-tight text-text-primary sm:text-6xl md:text-[4.5rem]" data-reveal data-reveal-delay="1">
          Accelerate growth<br />
          <span class="text-primary">with Next-Gen</span><br />
          AI marketing.
        </h1>

        <!-- Subtext -->
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-text-secondary" data-reveal data-reveal-delay="2">
          Hyperformance Media builds intelligent portals, websites, apps and campaigns that learn your market and compound your growth — engineered in Delhi, deployed everywhere.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row" data-reveal data-reveal-delay="3">
          <a
            href="/contact"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-8 py-3.5 text-body font-bold text-[#000000] shadow-card transition-all duration-300 hover:bg-primary-light hover:shadow-lg sm:w-auto"
          >
            Start your project
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 19L20 5M20 5v10M20 5H10" />
            </svg>
          </a>
          <a
            href="/services"
            class="inline-flex w-full items-center justify-center rounded-full border border-border bg-transparent px-8 py-3.5 text-body font-medium text-text-primary transition-all duration-300 hover:border-primary hover:text-primary sm:w-auto"
          >
            Explore services
          </a>
        </div>
      </div>

      <!-- Right side: Concentric Circles & Floating Logo -->
      <div class="relative mx-auto flex h-[500px] w-full max-w-lg items-center justify-center lg:mx-0 lg:max-w-none" data-reveal="fade" data-reveal-delay="3">
        
        <!-- Concentric rings (Centered explicitly) -->
        <div class="absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-primary/20 bg-transparent shadow-[inset_0_0_80px_rgba(0,229,255,0.05)]"></div>
        <div class="absolute left-1/2 top-1/2 h-[550px] w-[550px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-primary/10 bg-transparent"></div>
        
        <!-- Floating Logo: icon-only for dark, horizontal lockup for light -->
        <div class="relative z-10 flex items-center justify-center" style="animation: float-random 10s ease-in-out infinite;">
          <!-- Dark mode: square icon with black bg looks perfect inside the rings -->
          <Image 
            src={logoForHeroDark} 
            alt="Hyperformance Media" 
            class="hidden dark:block w-56 h-56 object-contain rounded-3xl drop-shadow-[0_0_60px_rgba(0,229,255,0.4)] md:w-72 md:h-72"
          />
          <!-- Light mode: horizontal lockup -->
          <Image 
            src={logoForHeroLight} 
            alt="Hyperformance Media" 
            class="block dark:hidden w-72 h-auto object-contain md:w-96"
          />
        </div>
      </div>
      
    </div>
  </div>

  <!-- Marquee Banner (Absolute Bottom) -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden bg-primary py-5">
    <div class="flex whitespace-nowrap" style="animation: marquee 20s linear infinite;">
      {marqueeItems.map((item) => (
        <span class="mx-4 text-2xl font-black uppercase tracking-widest text-[#000000]">
          {item}
        </span>
      ))}
      {/* Duplicate for seamless looping */}
      {marqueeItems.map((item) => (
        <span class="mx-4 text-2xl font-black uppercase tracking-widest text-[#000000]" aria-hidden="true">
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
