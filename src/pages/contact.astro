---
import BaseLayout from '../layouts/BaseLayout.astro';

// Real contact info - same values as Footer for consistency.
const contactInfo = [
  { label: 'Location', value: 'Rohini, Delhi - 110085', href: 'https://www.google.com/maps?q=28.69883918762207,77.11466979980469&z=17&hl=en', icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0zM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z' },
  { label: 'Phone', value: '+91-9643534849\n+91-7503325365', href: 'tel:+919643534849', icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z' },
  { label: 'Email', value: 'Hyperformancemedia@gmail.com', href: 'mailto:Hyperformancemedia@gmail.com', icon: 'M4 4h16v16H4zM22 6l-10 7L2 6' },
];

const hours = [
  { day: 'Monday - Saturday', time: '9:00 AM - 6:00 PM' },
  { day: 'Sunday', time: 'Closed' },
];
const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Us | Hyperformance Media',
  description: 'Get in touch with Hyperformance Media for a free digital marketing strategy call. Delhi-based, results-driven, AI-powered.',
  url: 'https://hyperformancemedia.in/contact',
};
---
<BaseLayout
	title="Contact Us | Hyperformance Media"
	description="Get in touch with Hyperformance Media for a free digital marketing strategy call. Delhi-based, results-driven, AI-powered."
	path="/contact"
	schema={contactSchema}
>
  <!-- Intro block -->
  <section class="bg-background px-6 pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary" data-reveal="fade">
        Get In Touch
      </span>
      <h1 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Let's Talk About Your Project</h1>
      <p class="mx-auto mt-6 max-w-2xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        Ready to grow your brand online? Send us a message and we'll get back to you within
        one business day.
      </p>
    </div>
  </section>

  <!-- Two-column: contact info (left) + form (right) -->
  <section class="bg-surface px-6 py-20 md:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- LEFT: contact info + hours + map placeholder -->
        <div class="space-y-8" data-reveal="left">
          <div>
            <h2 class="text-h3 text-text-primary">Contact Information</h2>
            <ul class="mt-6 space-y-5">
              {contactInfo.map((item) => (
                <li class="group flex items-start gap-4">
                  <div class="inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-button bg-primary/10 text-primary-dark transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-110">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <div class="text-body-sm font-medium text-text-secondary">{item.label}</div>
                    {item.href ? (
                      <a href={item.href} target={item.href.startsWith('http') ? '_blank' : '_self'} rel={item.href.startsWith('http') ? 'noopener noreferrer' : ''} class="text-body text-text-primary transition-colors hover:text-primary" style="white-space: pre-line;">
                        {item.value}
                      </a>
                    ) : (
                      <div class="text-body text-text-primary" style="white-space: pre-line;">{item.value}</div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Business hours -->
          <div class="rounded-card border border-border bg-background p-6 shadow-card transition-all duration-300 hover:shadow-card-hover">
            <h3 class="text-h4 text-text-primary">Business Hours</h3>
            <ul class="mt-4 space-y-2">
              {hours.map((h) => (
                <li class="flex items-center justify-between text-body text-text-secondary">
                  <span>{h.day}</span>
                  <span class="font-medium text-text-primary">{h.time}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Map integration (Rohini, Delhi) -->
          <div class="group relative flex flex-col overflow-hidden rounded-card border border-border bg-background shadow-card transition-all duration-300 hover:shadow-card-hover hover:border-primary/30" data-reveal="scale" data-reveal-delay="3">
            <div class="relative h-64 w-full">
              <iframe 
                src="https://maps.google.com/maps?q=28.69883918762207,77.11466979980469&z=17&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0; filter: grayscale(100%) invert(92%) contrast(1.1) brightness(0.9) sepia(100%) hue-rotate(180deg) saturate(3) brightness(0.8);" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
            <div class="flex items-center justify-between border-t border-border bg-surface/50 px-4 py-3 text-xs font-medium text-text-secondary">
              <span>Rohini, Delhi-110085</span>
              <a 
                href="https://www.google.com/maps?q=28.69883918762207,77.11466979980469&z=17&hl=en" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 font-semibold text-primary transition-colors hover:text-primary-light hover:underline"
              >
                Open in Google Maps
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- RIGHT: contact form wired to Hyperformancemedia@gmail.com -->
        <div class="rounded-card border border-border bg-background p-8 shadow-card transition-all duration-300 hover:shadow-card-hover" data-reveal="right">
          <h2 class="text-h3 text-text-primary">Send Us a Message</h2>
          <p class="mt-2 text-body-sm text-text-secondary">Queries are sent directly to Hyperformancemedia@gmail.com.</p>
          
          <div id="form-status" class="mt-4 hidden rounded-button p-4 text-sm font-medium"></div>

          <form id="contact-form" action="https://formsubmit.co/ajax/Hyperformancemedia@gmail.com" method="POST" class="mt-6 space-y-5" novalidate>
            <input type="hidden" name="_subject" value="New Lead from Hyperformance Media Website" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />

            <div>
              <label for="name" class="mb-1.5 block text-body-sm font-medium text-text-primary">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Doe"
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
              />
            </div>
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="email" class="mb-1.5 block text-body-sm font-medium text-text-primary">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@company.com"
                  class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="mb-1.5 block text-body-sm font-medium text-text-primary">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+91-XXXXXXXXXX"
                  class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
                />
              </div>
            </div>
            <div>
              <label for="service" class="mb-1.5 block text-body-sm font-medium text-text-primary">Service of Interest</label>
              <select
                id="service"
                name="service"
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
              >
                <option value="">Select a service...</option>
                <option value="Website Development">Website Development</option>
                <option value="Search Engine Optimisation">Search Engine Optimisation</option>
                <option value="App / CRM Development">App / CRM Development</option>
                <option value="E-Commerce">E-Commerce</option>
                <option value="Next-Gen AI Modelling">Next-Gen AI Modelling</option>
                <option value="Social Media Management">Social Media Management</option>
                <option value="Performance Marketing">Performance Marketing</option>
                <option value="Influencer Marketing">Influencer Marketing</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="mb-1.5 block text-body-sm font-medium text-text-primary">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell us about your project and goals..."
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors resize-none"
              ></textarea>
            </div>
            <button
              id="submit-btn"
              type="submit"
              class="w-full rounded-button bg-primary px-6 py-3.5 text-body font-medium text-black shadow-card transition-all duration-300 hover:bg-primary-light hover:shadow-lg hover:-translate-y-0.5 sm:w-auto"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusDiv = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  if (form && statusDiv && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('name') as HTMLInputElement)?.value;
      const email = (document.getElementById('email') as HTMLInputElement)?.value;
      const message = (document.getElementById('message') as HTMLTextAreaElement)?.value;

      if (!name || !email || !message) {
        statusDiv.className = 'mt-4 rounded-button p-4 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        statusDiv.textContent = 'Please fill out all required fields (Name, Email, and Message).';
        statusDiv.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      statusDiv.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          statusDiv.className = 'mt-4 rounded-button p-4 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
          statusDiv.textContent = '✅ Thank you! Your message has been sent directly to Hyperformancemedia@gmail.com. We will reach out within 24 hours.';
          statusDiv.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error('Failed to send');
        }
      } catch (err) {
        statusDiv.className = 'mt-4 rounded-button p-4 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        statusDiv.textContent = '❌ Something went wrong while sending your message. Please email us directly at Hyperformancemedia@gmail.com.';
        statusDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  }
</script>
