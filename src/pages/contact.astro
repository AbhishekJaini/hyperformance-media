---
import BaseLayout from '../layouts/BaseLayout.astro';

// Real contact info - same values as Footer for consistency.
const contactInfo = [
  { label: 'Location', value: 'Delhi, India', icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0zM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z' },
  { label: 'Phone', value: '+91-9643534849\n+91-7503325365', href: 'tel:+919643534849', icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z' },
  { label: 'Email', value: 'info@hyperformancemedia.in', href: 'mailto:info@hyperformancemedia.in', icon: 'M4 4h16v16H4zM22 6l-10 7L2 6' },
];

const hours = [
  { day: 'Monday - Friday', time: '9:00 AM - 6:00 PM' },
  { day: 'Saturday', time: '10:00 AM - 2:00 PM' },
  { day: 'Sunday', time: 'Closed' },
];
const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Us | Hyperformance Media',
  description: 'Get in touch with Hyperformance Media for a free digital marketing strategy call. Delhi-based, results-driven, AI-powered.',
  url: 'https://hyperformancemedia.in/contact',
};
---
<BaseLayout
	title="Contact Us | Hyperformance Media"
	description="Get in touch with Hyperformance Media for a free digital marketing strategy call. Delhi-based, results-driven, AI-powered."
	path="/contact"
	schema={contactSchema}
>
  <!-- Intro block -->
  <section class="bg-background px-6 pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary" data-reveal="fade">
        Get In Touch
      </span>
      <h1 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Let's Talk About Your Project</h1>
      <p class="mx-auto mt-6 max-w-2xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        Ready to grow your brand online? Send us a message and we'll get back to you within
        one business day.
      </p>
    </div>
  </section>

  <!-- Two-column: contact info (left) + form (right) -->
  <section class="bg-surface px-6 py-20 md:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- LEFT: contact info + hours + map placeholder -->
        <div class="space-y-8" data-reveal="left">
          <div>
            <h2 class="text-h3 text-text-primary">Contact Information</h2>
            <ul class="mt-6 space-y-5">
              {contactInfo.map((item) => (
                <li class="group flex items-start gap-4">
                  <div class="inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-button bg-primary/10 text-primary-dark transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-110">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <div class="text-body-sm font-medium text-text-secondary">{item.label}</div>
                    {item.href ? (
                      <a href={item.href} class="text-body text-text-primary transition-colors hover:text-primary" style="white-space: pre-line;">
                        {item.value}
                      </a>
                    ) : (
                      <div class="text-body text-text-primary" style="white-space: pre-line;">{item.value}</div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Business hours -->
          <div class="rounded-card border border-border bg-background p-6 shadow-card transition-all duration-300 hover:shadow-card-hover">
            <h3 class="text-h4 text-text-primary">Business Hours</h3>
            <ul class="mt-4 space-y-2">
              {hours.map((h) => (
                <li class="flex items-center justify-between text-body text-text-secondary">
                  <span>{h.day}</span>
                  <span class="font-medium text-text-primary">{h.time}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Map integration (Delhi, India) -->
          <div class="relative flex h-64 overflow-hidden rounded-card border border-border bg-background shadow-card transition-all duration-300 hover:shadow-card-hover hover:border-primary/30" data-reveal="scale" data-reveal-delay="3">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d224345.83923192776!2d77.0688975472278!3d28.52758200617607!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390cfd5b347eb62d%3A0x37205b715389640!2sDelhi!5e0!3m2!1sen!2sin!4v1715694203649!5m2!1sen!2sin" 
              width="100%" 
              height="100%" 
              style="border:0; filter: grayscale(100%) invert(92%) contrast(1.1) brightness(0.9) sepia(100%) hue-rotate(180deg) saturate(3) brightness(0.8);" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <!-- RIGHT: contact form (UI ONLY - no backend wiring yet) -->
        <!-- TODO: Wire form submission to a real handler (Formspree, Astro API route, etc.) -->
        <div class="rounded-card border border-border bg-background p-8 shadow-card transition-all duration-300 hover:shadow-card-hover" data-reveal="right">
          <h2 class="text-h3 text-text-primary">Send Us a Message</h2>
          <form id="contact-form" class="mt-6 space-y-5" novalidate toolname="contact_hyperformance" tooldescription="Send a message to Hyperformance Media to request a free strategy call or ask about services.">
            <div>
              <label for="name" class="mb-1.5 block text-body-sm font-medium text-text-primary">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                toolparamdescription="Full name of the person contacting us"
                required
                placeholder="Jane Doe"
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
              />
            </div>
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="email" class="mb-1.5 block text-body-sm font-medium text-text-primary">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  toolparamdescription="Email address for reply"
                  required
                  placeholder="jane@company.com"
                  class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="mb-1.5 block text-body-sm font-medium text-text-primary">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  toolparamdescription="Phone number with country code"
                  placeholder="+91-XXXXXXXXXX"
                  class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
                />
              </div>
            </div>
            <div>
              <label for="service" class="mb-1.5 block text-body-sm font-medium text-text-primary">Service of Interest</label>
              <select
                id="service"
                name="service"
                toolparamdescription="Service the user is interested in"
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
              >
                <option value="">Select a service...</option>
                <option value="web">Website Development</option>
                <option value="seo">Search Engine Optimisation</option>
                <option value="crm">App / CRM Development</option>
                <option value="ecommerce">E-Commerce</option>
                <option value="ai">Next-Gen AI Modelling</option>
                <option value="social">Social Media Management</option>
                <option value="ads">Performance Marketing</option>
                <option value="influencer">Influencer Marketing</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="mb-1.5 block text-body-sm font-medium text-text-primary">Message</label>
              <textarea
                id="message"
                name="message"
                toolparamdescription="Project details and goals"
                rows="5"
                required
                placeholder="Tell us about your project and goals..."
                class="w-full rounded-button border border-border bg-background px-4 py-3 text-body text-text-primary placeholder:text-text-secondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full rounded-button bg-primary px-6 py-3.5 text-body font-medium text-white shadow-card transition-all duration-300 hover:bg-primary-dark hover:shadow-lg hover:-translate-y-0.5 sm:w-auto"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Form handling placeholder - replace with real submission logic later.
     Options: Formspree, Astro API route (src/pages/api/contact.ts), or a CRM integration. -->
<script>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // Placeholder only - no backend wired yet.
      console.log('Contact form submitted (UI only - needs real handler).');
      alert('Thanks! This is a placeholder form. Real submission handling needs to be wired up.');
    });
  }
</script>
