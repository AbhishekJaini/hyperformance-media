---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found | Hyperformance Media"
  description="The page you are looking for cannot be found. Return to Hyperformance Media home page or explore our services."
  path="/404"
>
  <section class="relative overflow-hidden bg-background px-6 py-32 md:py-48 flex min-h-[70vh] items-center justify-center">
    <!-- Grid background -->
    <div class="pointer-events-none absolute inset-0 opacity-5">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="notFoundGrid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M60 0L0 0M0 0l0 60" stroke="currentColor" stroke-width="1" fill="none" class="text-text-primary" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#notFoundGrid)" />
      </svg>
    </div>

    <!-- Decorative ambient glows -->
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[100px]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-2xl text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-body-sm font-semibold uppercase tracking-wider text-primary shadow-sm" data-reveal="fade">
        Error 404
      </span>
      
      <h1 class="mt-8 text-7xl font-extrabold leading-tight tracking-tight text-text-primary sm:text-8xl md:text-9xl" data-reveal data-reveal-delay="1">
        404
      </h1>
      
      <h2 class="mt-6 text-2xl font-bold text-text-primary md:text-3xl" data-reveal data-reveal-delay="2">
        Lost in space?
      </h2>
      
      <p class="mx-auto mt-4 max-w-md text-body-lg text-text-secondary" data-reveal data-reveal-delay="3">
        The page you are looking for doesn't exist, has been moved, or is temporarily unavailable.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal data-reveal-delay="4">
        <a
          href="/"
          class="inline-flex w-full items-center justify-center rounded-full bg-primary px-8 py-3.5 text-body font-bold text-black shadow-card transition-all duration-300 hover:bg-primary-light hover:shadow-lg sm:w-auto"
        >
          Return Home
        </a>
        <a
          href="/services"
          class="inline-flex w-full items-center justify-center rounded-full border border-border bg-surface dark:bg-transparent px-8 py-3.5 text-body font-medium text-text-primary transition-all duration-300 hover:border-primary hover:text-primary sm:w-auto"
        >
          Our Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
