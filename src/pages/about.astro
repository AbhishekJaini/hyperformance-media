---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';
import { Image } from 'astro:assets';
import aboutGraphic from '../assets/about-graphic.jpg';

const values = [
  {
    title: 'Results-Driven',
    body: 'Every campaign is tied to measurable outcomes — traffic, leads, revenue. We optimize for impact, not vanity metrics.',
    icon: 'M3 3v18h18M7 14l4-4 3 3 5-6',
  },
  {
    title: 'Transparent',
    body: 'Clear reporting, honest communication, and no hidden fees. You always know what we are doing and why.',
    icon: 'M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
  },
  {
    title: 'AI-Forward',
    body: 'We leverage AI for research, content, and automation — so you get faster insights and smarter campaigns.',
    icon: 'M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-4 4 4 4 0 0 1-4-4V6a4 4 0 0 1 4-4zM6 20a6 6 0 0 1 12 0',
  },
  {
    title: 'Client-First',
    body: 'Your goals set the strategy. We adapt to your industry, audience, and budget — not the other way around.',
    icon: 'M17 20h5v-2a4 4 0 0 0-3-3.87M9 20H4v-2a4 4 0 0 1 3-3.87m6-1.13a4 4 0 1 0-4-4 4 4 0 0 0 4 4z',
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Us | Hyperformance Media',
  description: 'Hyperformance Media is a Delhi-based digital marketing agency helping brands grow through AI-powered SEO, web development, and performance marketing strategies.',
  url: 'https://hyperformancemedia.in/about',
};
---
<BaseLayout
	title="About Us | Hyperperformance Media"
	description="Hyperformance Media is a Delhi-based digital marketing agency helping brands grow through AI-powered SEO, web development, and performance marketing strategies."
	path="/about"
	schema={aboutSchema}
>
  <!-- Intro block -->
  <section class="relative overflow-hidden bg-background px-6 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="pointer-events-none absolute right-0 top-0 h-[500px] w-[500px] translate-x-1/3 -translate-y-1/3 rounded-full bg-primary/5 blur-[100px]" aria-hidden="true"></div>
    
    <div class="relative mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="max-w-2xl text-left">
          <span class="inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary shadow-sm" data-reveal="fade">
            <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
            About Us
          </span>
          <h1 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Who We Are</h1>
          <p class="mt-6 text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
            Hyperperformance Media is a Delhi-based digital marketing agency helping brands grow
            through AI-powered strategy, SEO, web design, and content. We blend data-driven
            thinking with creative execution to build online presence that converts.
          </p>
        </div>
        
        <div class="relative" data-reveal="scale" data-reveal-delay="2">
          <div class="relative rounded-2xl bg-surface/50 p-2 shadow-xl ring-1 ring-border/50">
            <Image 
              src={aboutGraphic} 
              alt="Hyperperformance Media Strategy and Growth" 
              class="w-full rounded-xl object-cover"
              width={600}
              height={600}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="relative overflow-hidden bg-surface px-6 py-20 md:py-28">
    <!-- Abstract pattern background -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(var(--color-primary) 1px, transparent 1px); background-size: 24px 24px;"></div>
    
    <div class="relative mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-background px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary shadow-sm" data-reveal="fade">
        <span class="inline-block h-2 w-2 rounded-full bg-primary" style="animation: dot-pulse 2.5s ease-in-out infinite;"></span>
        Our Story
      </span>
      <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">Built to Bridge Marketing and Technology</h2>
      <p class="mx-auto mt-6 max-w-3xl text-body-lg text-text-secondary" data-reveal data-reveal-delay="2">
        We started Hyperperformance Media after seeing too many brands stuck between
        traditional agencies that did not understand technology and tech shops that did not
        understand marketing. Our mission is simple: combine the best of both — performance
        marketing fundamentals with AI-powered tooling — to deliver growth that is
        measurable, sustainable, and scalable.
      </p>
    </div>
  </section>

  <!-- Values / Principles (4-card grid) -->
  <section class="bg-background px-6 py-20 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex items-center rounded-full bg-surface px-4 py-1.5 text-body-sm font-medium uppercase tracking-wider text-primary" data-reveal="fade">
          Our Values
        </span>
        <h2 class="mt-6 text-h2 text-text-primary" data-reveal data-reveal-delay="1">What We Stand For</h2>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((value, i) => (
          <div
            class="group rounded-card border border-border bg-background p-8 shadow-card transition-all duration-300 hover:shadow-card-hover hover:-translate-y-2 hover:border-primary/30"
            data-reveal="scale"
            data-reveal-delay={i + 1}
          >
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-button bg-primary/10 text-primary-dark transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-110 group-hover:rotate-3">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
              </svg>
            </div>
            <h3 class="mt-5 text-h4 text-text-primary">{value.title}</h3>
            <p class="mt-3 text-body text-text-secondary">{value.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
